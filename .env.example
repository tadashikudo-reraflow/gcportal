# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin
ADMIN_PASSWORD=your-admin-password

# Resend（メール配信）
RESEND_API_KEY=re_your-api-key

# Beehiiv（ニュースレター）
BEEHIIV_API_KEY=your-beehiiv-api-key
BEEHIIV_PUBLICATION_ID=pub_your-publication-id

# Telegram（管理者通知・任意）
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Vercel Cron（自動更新）
CRON_SECRET=your-cron-secret

# Google Analytics（任意）
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# X API v2（ニュースレター自動収集）
X_BEARER_TOKEN=your-x-bearer-token

# GCInsight Admin Key（Claude API認証）
GCINSIGHT_ADMIN_KEY=your-admin-key

# Note有料コミュニティ（準備できたらtrueに変更）
NOTE_CTA_ENABLED=false
NOTE_URL=https://note.com/your-account

# Resend Webhook署名検証（オプション）
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret
